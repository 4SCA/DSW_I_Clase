@model IEnumerable<CibertecDemo.Models.ProductoModel>;
@{
    ViewData["Title"] = "Lista de Productos";
}

<h2>Lista de Productos</h2>
<p><a class="btn btn-primary" asp-action="Create">+ Nuevo Producto</a></p>
<table class="table-bordered table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Cantidad</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @if(Model != null && Model.Any())
        {
            foreach(var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nombre</td>
                    <td>@item.Precio</td>
                    <td>@item.Cantidad</td>
                    <td>@item.Estado</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5">No hay productos registrados</td>
            </tr>
        }
    </tbody>
</table>
